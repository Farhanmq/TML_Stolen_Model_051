# Local OS/editor noise
.DS_Store
.vscode/
.idea/

# Environment/secrets
.env
.env.*
!.env.example

# Model artifacts and datasets (local machine paths, not portable)
artifacts/*
!artifacts/.gitkeep

# Intermediate per-suspect logit files (large, regenerated by extract_logits.py)
outputs/pairwise/logits/
outputs/**/*.npy

# Condor run logs
runlogs/*
!runlogs/.gitkeep

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
